NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
AUTO_RUN_MIGRATIONS=true

SQL_PROVIDER=postgres
SQL_CONNECTION_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
SQL_SSL=true
SQL_SSL_ALLOW_INVALID_CERTS=false

LLM_PROVIDER=openai-compatible
LLM_API_KEY=YOUR_LLM_API_KEY
LLM_MODEL=YOUR_LLM_MODEL
LLM_BASE_URL=https://YOUR_LLM_ENDPOINT
LLM_CLASSIFICATION_PATH=/chat/completions
LLM_TEMPERATURE=0.2

DEFAULT_BUCKETS=health,work,finance,relationships,growth,notes
