{
  "name": "lifetracker-api",
  "version": "1.0.0",
  "description": "Backend API for LifeTracker with switchable SQL and LLM configuration",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "node src/db/run_migrations.js",
    "check": "node --check src/server.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "pg": "^8.16.3"
  }
}
